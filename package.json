{
  "name": "markdown-typer",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm --parallel --filter @markdown-typer/api --filter @markdown-typer/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "pnpm --filter @markdown-typer/api test",
    "test:api": "pnpm --filter @markdown-typer/api test",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm format:check"
  },
  "devDependencies": {
    "prettier": "^3.5.3"
  }
}
